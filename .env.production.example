# ===== VPS Production Environment =====

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=loneos

# Supabase (when self-hosting, or direct Postgres connection)
NEXT_PUBLIC_SUPABASE_URL=http://YOUR_VPS_IP:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Meta Ads
NEXT_PUBLIC_META_APP_ID=3185055498548667

# Database URL (used internally by the app container)
DATABASE_URL=postgresql://postgres:CHANGE_ME@db:5432/loneos

# ===== Supabase (local via `npx supabase start`) =====
# These values are auto-generated by Supabase CLI
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== Meta Ads Integration =====
# 1. Crie um app em https://developers.facebook.com
# 2. Ative o produto "Marketing API"
# 3. Em Facebook Login > Settings, adicione o redirect URI: http://localhost:3000/traffic
# 4. Copie o App ID e cole abaixo
NEXT_PUBLIC_META_APP_ID=
# App Secret — usado SERVER-SIDE para trocar short-lived por long-lived token (60 dias)
# Nunca exponha no cliente. Adicione no .env.local (não commitado).
META_APP_SECRET=

# ===== Portal de Resultados (cliente público) =====
# Subdomínio onde o portal é acessado. Configurar CNAME no Cloudflare
# apontando resultados.lonemidia.com → painel.lonemidia.com
NEXT_PUBLIC_PORTAL_DOMAIN=https://resultados.lonemidia.com

# ===== Evolution API (WhatsApp — alertas de saldo p/ grupo do gestor) =====
# Valores REAIS vão no .env.local (não commitado). Aqui só placeholders.
# EVOLUTION_INSTANCE pode ter espaço (ex: "Ph lone midia") — o client faz URL-encode.
# Use a API Key da INSTÂNCIA (não a global).
EVOLUTION_API_URL=https://evo.lonemidia.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# Secret usado pelos crons (digest de saldos, check-meta-token, etc.)
CRON_SECRET=

# ===== Relatório semanal em PDF (browserless / headless chrome) =====
# Token do container browserless (gere uma string forte). O app conversa com o
# chromium pela rede interna; não há porta pública.
BROWSERLESS_TOKEN=
